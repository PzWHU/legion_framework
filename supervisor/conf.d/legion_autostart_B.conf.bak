[group:legion]
programs = setting,zenoh_bridge,canbus,routing,prediction,planning,control,legion_bridge

[program:setting]
directory=/home/beacon/legion_framework/scripts
command=/bin/bash /home/beacon/legion_framework/scripts/handle_autostart.sh setting
autostart=true
autorestart=false
startsecs=5
startretries=1
stopasgroup=false
redirect_stderr=true
stdout_logfile=/home/beacon/legion_framework/supervisor_logs/setting.log
stdout_logfile_maxbytes=10MB
stdout_logfile_backups=3
user=root
priority=1001
environment=
    HOME="/home/beacon",
    USER="beacon"

[program:zenoh_bridge]
directory=/home/beacon/legion_framework/scripts
command=/bin/bash /home/beacon/legion_framework/scripts/handle_autostart.sh zenoh_bridge
autostart=true
autorestart=false
startsecs=5
startretries=3
stopasgroup=true
redirect_stderr=true
stdout_logfile=/home/beacon/legion_framework/supervisor_logs/zenoh_bridge.log
stdout_logfile_maxbytes=50MB
stdout_logfile_backups=5
user=beacon
priority=1002
environment=
    HOME="/home/beacon",
    USER="beacon",
    ROS_DOMAIN_ID="0",
    RMW_IMPLEMENTATION="rmw_fastrtps_cpp",
    FASTRTPS_DEFAULT_PROFILES_FILE="/home/beacon/legion_framework/config/ros_fastdds.xml",
    ROS_LOG_DIR="/home/beacon/.ros/log",
    ROS_DISCOVERY_SERVER="192.168.1.101:11811"

[program:canbus]
directory=/home/beacon/legion_framework/scripts
command=/bin/bash /home/beacon/legion_framework/scripts/handle_autostart.sh canbus
autostart=true
autorestart=false
startsecs=10
startretries=3
stopasgroup=true
redirect_stderr=true
stdout_logfile=/home/beacon/legion_framework/supervisor_logs/canbus.log
