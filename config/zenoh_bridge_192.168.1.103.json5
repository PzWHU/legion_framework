{
  // ================================================
  // Zenoh Bridge ROS2DDS 配置文件
  // Legion Framework - C 端 (192.168.1.103) - 隔离模式
  // ================================================
  //
  // 隔离策略：
  // 1. 不连接任何外部 peer，保持完全孤立
  // 2. listen 监听本机 UDP 端口供本地节点通信
  // 3. scouting.multicast.enabled = false，禁用多播发现
  // 4. ros_localhost_only = true，仅处理本机 DDS 流量
  //
  mode: "peer",

  connect: {
    endpoints: [],
  },

  listen: {
    endpoints: ["udp/127.0.0.1:7447"],
  },

  scouting: {
    timeout: 10000,
    multicast: {
      enabled: false,
    },
  },

  plugins: {
    ros2dds: {
      ros_localhost_only: true,

      // ================================================
      // Topic 白名单过滤
      // allow:  白名单模式，只有匹配的话题被转发
      // deny:   黑名单模式，匹配的话题不转发
      // 只能同时使用 allow 或 deny，不能混用
      // ================================================

      // DDS → Zenoh：只允许 /drivers/canbus/Chassis 转发到网络
      // Zenoh → DDS：只允许从网络接收 /localization/global_fusion/Location
      allow: {
        publishers: ["/drivers/canbus/Chassis"],
        subscribers: ["/localization/global_fusion/Location"],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },
    },
  },
}
