{
  // ================================================
  // Zenoh Bridge ROS2DDS 配置文件
  // Legion Framework - B 端 (192.168.1.102) - 隔离 C 端 (103)
  // ================================================
  //
  // 隔离策略：
  // 1. 仅连接 A 端 (101)，不连接 C 端 (103)
  // 2. scout 多播发现正常，保持本机/跨机发现能力
  // 3. ros_localhost_only = false，允许跨机通信
  //
  mode: "peer",

  connect: {
    endpoints: ["udp/192.168.1.101:7447"],
  },

  listen: {
    endpoints: ["udp/0.0.0.0:7447"],
  },

  scouting: {
    timeout: 10000,
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto",
      listen: true,
    },
  },

  plugins: {
    ros2dds: {
      ros_localhost_only: false,

      // ================================================
      // Topic 白名单过滤
      // allow:  白名单模式，只有匹配的话题被转发
      // deny:   黑名单模式，匹配的话题不转发
      // 只能同时使用 allow 或 deny，不能混用
      // ================================================

      // DDS → Zenoh：只允许 /drivers/canbus/Chassis 转发到网络
      // Zenoh → DDS：只允许从网络接收 /localization/global_fusion/Location
      allow: {
        publishers: ["/drivers/canbus/Chassis"],
        subscribers: ["/localization/global_fusion/Location"],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },
    },
  },
}
