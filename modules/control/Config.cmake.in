@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_package(Boost REQUIRED COMPONENTS iostreams serialization filesystem system atomic)

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

set(@PROJECT_NAME@_INCLUDE_DIRS ${PACKAGE_PREFIX_DIR}/include ${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@/../ ${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@ ${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@/src)
set(@PROJECT_NAME@_LIBRARY_DIRS ${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@)
set(@PROJECT_NAME@_LIBRARIES @PROJECT_NAME@)

check_required_components(@PROJECT_NAME@)